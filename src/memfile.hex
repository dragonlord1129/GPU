// memfile.hex -- matrix-multiply kernel  C[4][16] = A[4][4] x B[4][16]
// auto layout: A@0  B@64  C@128 ; all 4 warps enter at PC 0 (blockIdx=warp id)
// (Verilog $readmemh ignores // comments; addresses 0..20, rest = HALT)
@00
00048200    // 00: ADDI r2, r0, 4        ; r2 = K = 4 (inner dim & loop bound)
0000532D    // 01: MUL  r3, r13, r2       ; r3 = i*4 = &A[i][0]  (baseA=0)
000054ED    // 02: MUL  r4, r13, r14      ; r4 = i*16
00808800    // 03: ADDI r8, r0, 128      ; r8 = baseC = 128
00000484    // 04: ADD  r4, r4, r8        ; r4 = baseC + i*16
000004F4    // 05: ADD  r4, r4, r15       ; r4 = &C[i][j]
00408700    // 06: ADDI r7, r0, 64       ; r7 = baseB = 64
00008500    // 07: ADDI r5, r0, 0        ; r5 = acc = 0
00008600    // 08: ADDI r6, r0, 0        ; r6 = k = 0
00000A63    // 09: ADD  r10, r3, r6       ; r10 = &A[i][k]   (LOOP)
00006B0A    // 0A: LW   r11, r10, 0      ; r11 = A[i][k]   (broadcast load)
00005CE6    // 0B: MUL  r12, r6, r14      ; r12 = k*16
00000C7C    // 0C: ADD  r12, r12, r7      ; r12 = baseB + k*16
00000CFC    // 0D: ADD  r12, r12, r15     ; r12 = &B[k][j]
0000610C    // 0E: LW   r1, r12, 0       ; r1  = B[k][j]   (coalesced load)
00005B1B    // 0F: MUL  r11, r11, r1      ; r11 = A[i][k]*B[k][j]
000005B5    // 10: ADD  r5, r5, r11       ; acc += product
00018606    // 11: ADDI r6, r6, 1        ; k++
FFF7C026    // 12: BLT  r6, r2, LOOP     ; if (k < K) goto LOOP  (imm = 9-18 = -9)
00007054    // 13: SW   r5, r4, 0        ; C[i][j] = acc   (coalesced store)
0000F000    // 14: HALT
// ---- remaining instruction memory: HALT ----
@15
